// ── STATE ─────────────────────────────────────────────────────────────────────
let margin     = 20;
let viewMode   = 'table'; // 'table' | 'cards'
let selMode    = false;
let selected   = new Set();
let filtered   = [];
let mgFilter   = 'all';

// ── HELPERS ──────────────────────────────────────────────────────────────────
const fmt = n => n > 0 ? n.toLocaleString('es-ES', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €' : '—';
const fmtPct = n => (n >= 0 ? '+' : '') + (n*100).toFixed(1) + '%';
const pvpSugg = (precio) => margin === 0 ? null : precio / (1 - margin/100);
const pctClass = (g) => g >= .30 ? 'pct-high' : g >= .15 ? 'pct-mid' : g >= 0 ? 'pct-low' : 'pct-neg';
const escHtml = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

// ── POPULATE FILTERS ─────────────────────────────────────────────────────────
function populateFilters() {
  const brands = [...new Set(ALL_PRODUCTS.map(p=>p.marca))].sort();
  const cats   = [...new Set(ALL_PRODUCTS.map(p=>p.categoria))].sort();
  const mSel = document.getElementById('marcaFilter');
  const cSel = document.getElementById('catFilter');
  brands.forEach(b => { const o=document.createElement('option'); o.value=o.textContent=b; mSel.appendChild(o); });
  cats.forEach(c   => { const o=document.createElement('option'); o.value=o.textContent=c; cSel.appendChild(o); });
}

// ── FILTER & SORT ─────────────────────────────────────────────────────────────
function applyFilters() {
  const q     = document.getElementById('searchInput').value.toLowerCase().trim();
  const marca = document.getElementById('marcaFilter').value;
  const cat   = document.getElementById('catFilter').value;
  const stock = document.getElementById('chkStock').checked;
  const top   = document.getElementById('chkTop').checked;
  const sort  = document.getElementById('sortSel').value;

  filtered = ALL_PRODUCTS.filter(p => {
    if (marca && p.marca !== marca) return false;
    if (cat   && p.categoria !== cat) return false;
    if (stock && p.stock <= 0) return false;
    if (top   && !p.top) return false;
    if (mgFilter === 'high' && p.ganancia < .30) return false;
    if (mgFilter === 'mid'  && (p.ganancia < .15 || p.ganancia >= .30)) return false;
    if (mgFilter === 'low'  && p.ganancia >= .15) return false;
    if (q) {
      const hay = (p.nombre + ' ' + p.marca + ' ' + p.familia + ' ' + p.categoria).toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });

  filtered.sort((a,b) => {
    switch(sort) {
      case 'priceAsc':    return a.precio - b.precio;
      case 'priceDesc':   return b.precio - a.precio;
      case 'marginDesc':  return b.ganancia - a.ganancia;
      case 'stockDesc':   return b.stock - a.stock;
      case 'topFirst':    return (b.top?1:0) - (a.top?1:0);
      default:            return a.nombre.localeCompare(b.nombre,'es');
    }
  });

  renderStats();
  if (viewMode === 'table') renderTable();
  else renderCards();
  document.getElementById('resultCount').textContent =
    `${filtered.length.toLocaleString('es-ES')} producto${filtered.length!==1?'s':''} mostrado${filtered.length!==1?'s':''}`;
}

// ── RENDER STATS ─────────────────────────────────────────────────────────────
function renderStats() {
  const brands = new Set(filtered.map(p=>p.marca));
  document.getElementById('statTotal').textContent  = ALL_PRODUCTS.length;
  document.getElementById('statTop').textContent    = ALL_PRODUCTS.filter(p=>p.top).length;
  document.getElementById('statStock').textContent  = ALL_PRODUCTS.filter(p=>p.stock>0).length;
  document.getElementById('statBrands').textContent = [...new Set(ALL_PRODUCTS.map(p=>p.marca))].length;
}

// ── RENDER TABLE ─────────────────────────────────────────────────────────────
function renderTable() {
  const tbody = document.getElementById('tableBody');
  const hdr   = document.getElementById('selHeader');
  hdr.style.display = selMode ? '' : 'none';

  if (!filtered.length) {
    tbody.innerHTML = '';
    document.getElementById('tableEmpty').style.display = '';
    return;
  }
  document.getElementById('tableEmpty').style.display = 'none';

  tbody.innerHTML = filtered.map(p => {
    const sugg = pvpSugg(p.precio);
    const inSel = selected.has(p.id);
    const topBadge = p.top ? '<span class="badge-top">⭐</span>' : '';
    const nameHtml = p.link
      ? `${topBadge}<a href="${escHtml(p.link)}" target="_blank">${escHtml(p.nombre)}</a>`
      : `${topBadge}<span class="no-link">${escHtml(p.nombre)}</span>`;
    const stockHtml = p.stock > 0
      ? `<span class="badge-stock"><span class="dot dot-green"></span>${p.stock.toLocaleString('es-ES')}</span>`
      : `<span class="badge-stock"><span class="dot dot-red"></span>Sin stock</span>`;
    const selCell = selMode
      ? `<td class="check-col"><input type="checkbox" class="row-check" data-id="${p.id}" ${inSel?'checked':''}></td>`
      : '';

    return `<tr data-id="${p.id}" class="${inSel&&selMode?'selected':''}">
      ${selCell}
      <td class="td-name"><div>${nameHtml}</div><div class="familia-tag">${escHtml(p.familia)}</div></td>
      <td><span class="marca-badge">${escHtml(p.marca)}</span></td>
      <td style="font-size:.78rem;color:var(--pcc-muted)">${escHtml(p.categoria)}</td>
      <td class="price price-pvpr">${fmt(p.pvpr)}</td>
      <td class="price">${p.pvpweb>0?fmt(p.pvpweb):'<span style="color:var(--pcc-muted)">—</span>'}</td>
      <td class="price" style="color:var(--pcc-orange)">${fmt(p.precio)}</td>
      <td><span class="pct-badge ${pctClass(p.ganancia)}">${fmtPct(p.ganancia)}</span></td>
      <td class="pvp-suggested">${sugg?fmt(sugg):'—'}</td>
      <td>${stockHtml}</td>
    </tr>`;
  }).join('');

  // bind row checkboxes
  tbody.querySelectorAll('.row-check').forEach(cb => {
    cb.addEventListener('change', e => {
      e.stopPropagation();
      toggleSelect(+cb.dataset.id);
    });
  });
  if (selMode) {
    tbody.querySelectorAll('tr[data-id]').forEach(tr => {
      tr.addEventListener('click', e => {
        if (e.target.classList.contains('row-check') || e.target.tagName==='A') return;
        toggleSelect(+tr.dataset.id);
      });
    });
  }
}

// ── RENDER CARDS ─────────────────────────────────────────────────────────────
function renderCards() {
  const grid = document.getElementById('cardsGrid');
  if (!filtered.length) {
    grid.innerHTML = '';
    document.getElementById('cardsEmpty').style.display = '';
    return;
  }
  document.getElementById('cardsEmpty').style.display = 'none';

  grid.innerHTML = filtered.map(p => {
    const sugg   = pvpSugg(p.precio);
    const inSel  = selected.has(p.id);
    const topBadge = p.top ? '<span class="badge-top" style="margin-bottom:4px;display:inline-block">⭐ Top</span>' : '';
    const stockHtml = p.stock > 0
      ? `<span class="badge-stock"><span class="dot dot-green"></span>${p.stock.toLocaleString('es-ES')}</span>`
      : `<span class="badge-stock"><span class="dot dot-red"></span>Sin stock</span>`;
    const linkHtml = p.link
      ? `<a class="card-link" href="${escHtml(p.link)}" target="_blank">Ver en web ↗</a>`
      : `<span class="card-no-link">Sin link</span>`;
    const checkHtml = selMode
      ? `<input type="checkbox" class="card-check" data-id="${p.id}" ${inSel?'checked':''}>`
      : '';
    return `<div class="card${inSel&&selMode?' selected':''}" data-id="${p.id}">
      ${checkHtml}
      <div class="card-top">
        <span class="marca-badge">${escHtml(p.marca)}</span>
        <span class="pct-badge ${pctClass(p.ganancia)}">${fmtPct(p.ganancia)}</span>
      </div>
      ${topBadge}
      <div class="card-name">${escHtml(p.nombre)}</div>
      <div class="card-familia">${escHtml(p.familia)}</div>
      <div class="card-prices">
        <div class="card-price-block">
          <div class="card-price-lbl">Precio Reseller</div>
          <div class="card-price-val" style="color:var(--pcc-orange)">${fmt(p.precio)}</div>
        </div>
        <div class="card-price-block">
          <div class="card-price-lbl">PVP Sugerido (${margin}%)</div>
          <div class="card-price-val" style="color:var(--pcc-green)">${sugg?fmt(sugg):'—'}</div>
        </div>
      </div>
      <div class="card-footer">
        ${stockHtml}
        ${linkHtml}
      </div>
    </div>`;
  }).join('');

  grid.querySelectorAll('.card-check').forEach(cb => {
    cb.addEventListener('change', e => { e.stopPropagation(); toggleSelect(+cb.dataset.id); });
  });
  if (selMode) {
    grid.querySelectorAll('.card[data-id]').forEach(card => {
      card.addEventListener('click', e => {
        if (e.target.classList.contains('card-check') || e.target.tagName==='A') return;
        toggleSelect(+card.dataset.id);
      });
    });
  }
}

// ── SELECTION ─────────────────────────────────────────────────────────────────
function toggleSelect(id) {
  if (selected.has(id)) selected.delete(id); else selected.add(id);
  updateSelBar();
  if (viewMode === 'table') {
    const tr = document.querySelector(`tr[data-id="${id}"]`);
    if (tr) {
      tr.classList.toggle('selected', selected.has(id));
      const cb = tr.querySelector('.row-check');
      if (cb) cb.checked = selected.has(id);
    }
  } else {
    const card = document.querySelector(`.card[data-id="${id}"]`);
    if (card) {
      card.classList.toggle('selected', selected.has(id));
      const cb = card.querySelector('.card-check');
      if (cb) cb.checked = selected.has(id);
    }
  }
}

function updateSelBar() {
  const bar = document.getElementById('selBar');
  const selItems = ALL_PRODUCTS.filter(p => selected.has(p.id));
  const total = selItems.reduce((s,p) => s + p.precio, 0);
  document.getElementById('selCount').textContent = `${selected.size} producto${selected.size!==1?'s':''} seleccionado${selected.size!==1?'s':''}`;
  document.getElementById('selTotal').innerHTML = `Precio total estimado (precio Reseller) <strong>${fmt(total)}</strong>`;
  bar.classList.toggle('visible', selMode && selected.size > 0);
  document.getElementById('mainContent').classList.toggle('bar-visible', selMode && selected.size > 0);
}

// ── EXPORT CSV ────────────────────────────────────────────────────────────────
function exportCsv(items, filename) {
  const sugg = p => pvpSugg(p.precio);
  const headers = ['ID','Marca','Categoría','Familia','Nombre','PVPR','PVP Web','Precio Reseller','% Ganancia','PVP Sugerido','Stock','Link'];
  const rows = items.map(p => [
    p.id, p.marca, p.categoria, p.familia,
    '"'+p.nombre.replace(/"/g,'""')+'"',
    p.pvpr, p.pvpweb||'', p.precio,
    (p.ganancia*100).toFixed(2)+'%',
    sugg(p) ? sugg(p).toFixed(2) : '',
    p.stock, p.link
  ]);
  const csv = [headers, ...rows].map(r => r.join(';')).join('\n');
  const blob = new Blob(['\uFEFF'+csv], {type:'text/csv;charset=utf-8;'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = filename;
  a.click();
}

// ── EVENTS ───────────────────────────────────────────────────────────────────
// search + filters
['searchInput','marcaFilter','catFilter','sortSel'].forEach(id => {
  document.getElementById(id).addEventListener('input', applyFilters);
});
['chkStock','chkTop'].forEach(id => {
  document.getElementById(id).addEventListener('change', applyFilters);
});

// margin slider
document.getElementById('marginSlider').addEventListener('input', function() {
  margin = +this.value;
  document.getElementById('marginLabel').textContent = margin + '%';
  document.getElementById('marginHint').textContent =
    margin === 0 ? 'Sin margen objetivo' : `PVP sugerido = Precio Reseller ÷ ${(1 - margin/100).toFixed(2)}`;
  if (viewMode === 'table') renderTable(); else renderCards();
});

// margin pills
document.querySelectorAll('.mpill').forEach(pill => {
  pill.addEventListener('click', function() {
    document.querySelectorAll('.mpill').forEach(p => p.classList.remove('active'));
    this.classList.add('active');
    mgFilter = this.dataset.mg;
    applyFilters();
  });
});

// view toggle
document.getElementById('btnTable').addEventListener('click', () => {
  viewMode = 'table';
  document.getElementById('btnTable').classList.add('active');
  document.getElementById('btnCards').classList.remove('active');
  document.getElementById('tableView').style.display = '';
  document.getElementById('cardsView').style.display = 'none';
  renderTable();
});
document.getElementById('btnCards').addEventListener('click', () => {
  viewMode = 'cards';
  document.getElementById('btnCards').classList.add('active');
  document.getElementById('btnTable').classList.remove('active');
  document.getElementById('tableView').style.display = 'none';
  document.getElementById('cardsView').style.display = '';
  renderCards();
});

// selection toggle
document.getElementById('selToggleBtn').addEventListener('click', () => {
  selMode = !selMode;
  const btn = document.getElementById('selToggleBtn');
  if (selMode) { btn.classList.add('sel-active'); btn.textContent = '✕ Cancelar selección'; }
  else { btn.classList.remove('sel-active'); btn.textContent = '☑ Seleccionar'; selected.clear(); }
  updateSelBar();
  if (viewMode === 'table') renderTable(); else renderCards();
});

// export all visible
document.getElementById('exportCsvBtn').addEventListener('click', () => {
  exportCsv(filtered, `tarifa-reseller-${new Date().toISOString().slice(0,10)}.csv`);
});

// export selection
document.getElementById('exportSelBtn').addEventListener('click', () => {
  const items = ALL_PRODUCTS.filter(p => selected.has(p.id));
  if (!items.length) return;
  exportCsv(items, `seleccion-reseller-${new Date().toISOString().slice(0,10)}.csv`);
});

// clear selection
document.getElementById('clearSelBtn').addEventListener('click', () => {
  selected.clear();
  updateSelBar();
  if (viewMode === 'table') renderTable(); else renderCards();
});

// copy links
document.getElementById('copyLinksBtn').addEventListener('click', () => {
  const links = ALL_PRODUCTS.filter(p => selected.has(p.id) && p.link).map(p => p.nombre + '\n' + p.link);
  if (!links.length) return;
  navigator.clipboard.writeText(links.join('\n\n')).then(() => {
    const btn = document.getElementById('copyLinksBtn');
    btn.textContent = '✓ ¡Copiado!';
    setTimeout(() => { btn.textContent = '🔗 Copiar links'; }, 2000);
  });
});

// help modal
document.getElementById('helpBtn').addEventListener('click', () => {
  document.getElementById('helpModal').classList.add('open');
});
document.getElementById('modalCloseBtn').addEventListener('click', () => {
  document.getElementById('helpModal').classList.remove('open');
});
document.getElementById('helpModal').addEventListener('click', e => {
  if (e.target === document.getElementById('helpModal')) document.getElementById('helpModal').classList.remove('open');
});

// ── INIT ─────────────────────────────────────────────────────────────────────
populateFilters();
applyFilters();
</script>
