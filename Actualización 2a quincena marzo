let currentView = 'table';
let selectMode = false;
let selected = new Set();
let marginPct = 20;
let filtered = [];

const marginSlider = document.getElementById('marginSlider');
const marginDisplay = document.getElementById('marginDisplay');

marginSlider.addEventListener('input', () => {
  marginPct = +marginSlider.value;
  marginDisplay.textContent = marginPct + '%';
  render();
});

document.getElementById('filterMarca').addEventListener('change', render);
document.getElementById('filterCategoria').addEventListener('change', render);
document.getElementById('filterStock').addEventListener('change', render);
document.getElementById('filterTop').addEventListener('change', render);
document.getElementById('searchInput').addEventListener('input', render);
document.getElementById('sortSel').addEventListener('change', render);

document.querySelectorAll('.chip[data-margin]').forEach(chip => {
  chip.addEventListener('click', () => {
    document.querySelectorAll('.chip[data-margin]').forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
    render();
  });
});

function pvpSugerido(precio) {
  return precio / (1 - marginPct / 100);
}

function fmtEur(v) {
  return v.toFixed(2).replace('.', ',') + ' €';
}

function marginClass(m) {
  if (m === null) return '';
  if (m >= 30) return 'margin-high';
  if (m >= 15) return 'margin-mid';
  return 'margin-low';
}

function stockLabel(s) {
  if (s > 100) return `<span class="stock-badge stock-ok">✓ ${s}</span>`;
  if (s > 0)   return `<span class="stock-badge stock-low">⚠ ${s}</span>`;
  return `<span class="stock-badge stock-out">Sin stock</span>`;
}

function getFiltered() {
  const marca = document.getElementById('filterMarca').value;
  const cat = document.getElementById('filterCategoria').value;
  const onlyStock = document.getElementById('filterStock').checked;
  const onlyTop = document.getElementById('filterTop').checked;
  const search = document.getElementById('searchInput').value.trim().toLowerCase();
  const marginFilter = document.querySelector('.chip[data-margin].active')?.dataset.margin || 'all';
  const sort = document.getElementById('sortSel').value;

  let arr = PRODUCTS.filter(p => {
    if (marca && p.marca !== marca) return false;
    if (cat && p.categoria !== cat) return false;
    if (onlyStock && p.stock <= 0) return false;
    if (onlyTop && !p.top) return false;
    if (search) {
      const hay = (p.nombre + ' ' + p.marca + ' ' + p.id).toLowerCase();
      if (!hay.includes(search)) return false;
    }
    if (marginFilter === 'high' && (p.margen === null || p.margen < 30)) return false;
    if (marginFilter === 'mid' && (p.margen === null || p.margen < 15 || p.margen >= 30)) return false;
    if (marginFilter === 'low' && (p.margen === null || p.margen >= 15)) return false;
    return true;
  });

  arr.sort((a, b) => {
    if (sort === 'name') return a.nombre.localeCompare(b.nombre);
    if (sort === 'price_asc') return a.precio - b.precio;
    if (sort === 'price_desc') return b.precio - a.precio;
    if (sort === 'margin_desc') return (b.margen ?? -999) - (a.margen ?? -999);
    if (sort === 'stock_desc') return b.stock - a.stock;
    if (sort === 'top_first') return (b.top ? 1 : 0) - (a.top ? 1 : 0);
    return 0;
  });

  return arr;
}

function render() {
  filtered = getFiltered();
  document.getElementById('resultCount').textContent = filtered.length + ' productos';
  const content = document.getElementById('mainContent');
  if (filtered.length === 0) {
    content.innerHTML = '<div class="empty"><div class="empty-icon">🔍</div><p>No hay productos con estos filtros.</p></div>';
    return;
  }
  if (currentView === 'table') renderTable(content);
  else renderCards(content);
  updateBottomBar();
}

function renderTable(container) {
  const checkCol = selectMode ? '<th class="td-check"></th>' : '';
  let rows = filtered.map(p => {
    const pvp = pvpSugerido(p.precio);
    const mc = marginClass(p.margen);
    const topBadge = p.top ? '⭐ ' : '';
    const checkCell = selectMode
      ? `<td class="td-check"><input type="checkbox" ${selected.has(p.id) ? 'checked' : ''} onchange="toggleProduct('${p.id}', this)"></td>`
      : '';
    const linkCell = p.link ? `<a class="link-btn" href="${p.link}" target="_blank">Ver →</a>` : '—';
    return `<tr class="${selected.has(p.id) ? 'selected' : ''}">
      ${checkCell}
      <td><div class="prod-name">${topBadge}${escHtml(p.nombre)}</div><div class="prod-brand">${escHtml(p.marca)} · ${escHtml(p.familia)}</div></td>
      <td><span class="price">${fmtEur(p.precio)}</span>${p.pvpr ? '<br><span class="pvpr">' + fmtEur(p.pvpr) + '</span>' : ''}</td>
      <td><span class="pvp-sug">${fmtEur(pvp)}</span></td>
      <td>${p.margen !== null ? `<span class="margin-badge ${mc}">${p.margen.toFixed(1)}%</span>` : '—'}</td>
      <td>${stockLabel(p.stock)}</td>
      <td>${linkCell}</td>
    </tr>`;
  }).join('');

  container.innerHTML = `<div class="table-wrap"><table>
    <thead><tr>
      ${checkCol}
      <th>Producto</th>
      <th>Precio Reseller</th>
      <th>PVP sugerido (${marginPct}%)</th>
      <th>Margen</th>
      <th>Stock</th>
      <th>Link</th>
    </tr></thead>
    <tbody>${rows}</tbody>
  </table></div>`;
}

function renderCards(container) {
  const cards = filtered.map(p => {
    const pvp = pvpSugerido(p.precio);
    const mc = marginClass(p.margen);
    const topBadge = p.top ? '<span class="card-top">⭐ Top</span>' : '';
    const checkEl = selectMode
      ? `<div class="card-check"><input type="checkbox" ${selected.has(p.id) ? 'checked' : ''} onchange="toggleProduct('${p.id}', this)"></div>`
      : '';
    const linkEl = p.link ? `<a class="link-btn" href="${p.link}" target="_blank">Ver en web →</a>` : '';
    return `<div class="card ${selected.has(p.id) ? 'selected' : ''}">
      ${checkEl}
      ${topBadge}
      <div class="card-brand">${escHtml(p.marca)}</div>
      <div class="card-name">${escHtml(p.nombre)}</div>
      <div class="card-prices">
        <span class="card-price">${fmtEur(p.precio)}</span>
        ${p.pvpr ? `<span class="card-pvpr">${fmtEur(p.pvpr)}</span>` : ''}
      </div>
      <div class="card-row">
        <span style="font-size:12px;color:var(--text-muted)">PVP sug. (${marginPct}%)</span>
        <span class="card-pvp-sug">${fmtEur(pvp)}</span>
      </div>
      <div class="card-footer">
        <span>${p.margen !== null ? `<span class="margin-badge ${mc}">${p.margen.toFixed(1)}%</span>` : ''}</span>
        <span>${stockLabel(p.stock)}</span>
      </div>
      ${linkEl ? `<div style="margin-top:8px">${linkEl}</div>` : ''}
    </div>`;
  }).join('');
  container.innerHTML = `<div class="cards-grid">${cards}</div>`;
}

function escHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function setView(v) {
  currentView = v;
  document.getElementById('btnTable').classList.toggle('active', v === 'table');
  document.getElementById('btnCards').classList.toggle('active', v === 'cards');
  render();
}

function toggleSelect() {
  selectMode = !selectMode;
  const btn = document.getElementById('btnSelect');
  btn.textContent = selectMode ? 'Cancelar' : 'Seleccionar';
  btn.classList.toggle('active', selectMode);
  if (!selectMode) {
    selected.clear();
    document.getElementById('bottomBar').classList.remove('visible');
  } else {
    document.getElementById('bottomBar').classList.add('visible');
  }
  render();
}

function toggleProduct(id, checkbox) {
  if (checkbox.checked) selected.add(id);
  else selected.delete(id);
  updateBottomBar();
  // Update row/card highlight
  render();
}

function updateBottomBar() {
  const count = selected.size;
  document.getElementById('selCount').textContent = count + ' producto' + (count !== 1 ? 's' : '') + ' seleccionado' + (count !== 1 ? 's' : '');
  const total = PRODUCTS.filter(p => selected.has(p.id)).reduce((s, p) => s + p.precio, 0);
  document.getElementById('selTotal').textContent = fmtEur(total);
  if (selectMode) document.getElementById('bottomBar').classList.add('visible');
}

function clearSelection() {
  selected.clear();
  updateBottomBar();
  render();
}

function exportCSV() {
  const cols = ['ID','Marca','Categoría','Familia','Nombre','Precio Reseller','PVPR','PVP Sugerido','Margen %','Stock','Link'];
  const rows = filtered.map(p => [
    p.id, p.marca, p.categoria, p.familia, p.nombre,
    p.precio, p.pvpr ?? '', pvpSugerido(p.precio).toFixed(2),
    p.margen !== null ? p.margen.toFixed(1) : '', p.stock, p.link
  ]);
  downloadCSV(cols, rows, 'tarifa-reseller.csv');
}

function exportSelectionCSV() {
  const sel = PRODUCTS.filter(p => selected.has(p.id));
  const cols = ['ID','Marca','Categoría','Familia','Nombre','Precio Reseller','PVPR','PVP Sugerido','Margen %','Stock','Link'];
  const rows = sel.map(p => [
    p.id, p.marca, p.categoria, p.familia, p.nombre,
    p.precio, p.pvpr ?? '', pvpSugerido(p.precio).toFixed(2),
    p.margen !== null ? p.margen.toFixed(1) : '', p.stock, p.link
  ]);
  downloadCSV(cols, rows, 'seleccion-reseller.csv');
}

function downloadCSV(cols, rows, filename) {
  const BOM = '﻿';
  const lines = [cols, ...rows].map(r => r.map(c => `"${String(c).replace(/"/g,'""')}"`).join(';'));
  const blob = new Blob([BOM + lines.join('\n')], { type: 'text/csv;charset=utf-8;' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = filename;
  a.click();
}

function copyLinks() {
  const links = PRODUCTS.filter(p => selected.has(p.id) && p.link).map(p => p.link).join('\n');
  if (!links) { alert('No hay productos seleccionados con link.'); return; }
  navigator.clipboard.writeText(links).then(() => alert('Links copiados al portapapeles.'));
}

// Init
render();
</script>
